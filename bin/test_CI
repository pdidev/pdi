# Use "./test_CI" to run CI locally from a container

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# ----------- Config ------------------
IMAGE="ghcr.io/pdidev/ubuntu/rolling/openmpi/all:v4"
TMP_DIR="/tmp_dir_test"
BINARY_PATH="bin/build_and_run_all_tests"
# ------------------------------------

if [[ ! -f "$BINARY_PATH" ]]; then
    echo "Error: Test runner script not found at $REPO_ROOT/$BINARY_PATH" >&2
    exit 1
fi

CONTAINER_OPTS=(run --rm)

if command -v docker &>/dev/null; then
    CONTAINER_CMD="docker"
    CONTAINER_OPTS+=("--user" "$(id -u):$(id -g)")
elif command -v podman &>/dev/null; then
    CONTAINER_CMD="podman"
    CONTAINER_OPTS+=("--userns=keep-id")
else
    echo "Error: neither docker nor podman found in PATH" >&2
    exit 127
fi

echo "Running CI tests via $CONTAINER_CMD"
echo ""

"$CONTAINER_CMD" "${CONTAINER_OPTS[@]}" \
    -v "$REPO_ROOT":/src \
    -w /src \
    --tmpfs "${TMP_DIR}:exec" \
    -e MAKEFLAGS="-j 4" \
    -e TEST_DIR="$TMP_DIR" \
    -e CMAKE_FLAGS="-DBUILD_DOCUMENTATION=OFF" \
    "$IMAGE" \
    "/src/$BINARY_PATH"

echo ""
echo "Done"
