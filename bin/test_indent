# Use "./test_indent" to run check
# Use "./test_indent -i" to apply fix

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

IMAGE="ghcr.io/pdidev/run_clang_format:v4"
CONTAINER_OPTS=(run --rm)

CLANG_FORMAT_ARGS=()
if [ $# -gt 0 ]; then
    case "$1" in
        -i|--apply)
            CLANG_FORMAT_ARGS+=("-i")
            ;;
        -q|--quiet)
            CLANG_FORMAT_ARGS+=("-q")
            ;;
        -h|--help)
            echo "Usage: $0 [-i|--apply] [-q|--quiet]" >&2
            echo "  Checks (or with -i/--apply, enforces) the indentation of C/C++ files" >&2
            echo "  With -q/--quiet, only the return code provides info" >&2
            exit 0
            ;;
        *)
            echo "Error: Unknown option '$1'" >&2
            echo "Usage: $0 [-i|--apply] [-q|--quiet]" >&2
            exit 1
            ;;
    esac
fi

if command -v docker &>/dev/null; then
    CONTAINER_CMD="docker"
    CONTAINER_OPTS+=("--user" "$(id -u):$(id -g)")
elif command -v podman &>/dev/null; then
    CONTAINER_CMD="podman"
    CONTAINER_OPTS+=("--userns=keep-id")
else
    echo "Error: neither docker nor podman found in PATH" >&2
    exit 127
fi

echo "Collecting files and running clang-format via $CONTAINER_CMD"

git ls-files -z --full-name \
    | grep -zZv '^vendor/' \
    | grep -zZE '\.(c|h|cc|hh|cpp|hpp|cxx|hxx)$' \
    | xargs -0 "$CONTAINER_CMD" "${CONTAINER_OPTS[@]}" -v "$REPO_ROOT":/src -w /src "$IMAGE" "${CLANG_FORMAT_ARGS[@]}"

echo "Done"
